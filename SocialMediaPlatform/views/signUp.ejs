<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Signup</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background: linear-gradient(to right, #43e97b, #38f9d7);
    }
    .card {
      border-radius: 15px;
    }
  </style>
</head>

<body>
<nav style="
  position: absolute;
  top: 0;
  width: 100%;
  padding: 15px 0;
  text-align: center;
  backdrop-filter: blur(10px);
  background: rgba(255,255,255,0.1);
  border-bottom: 1px solid rgba(255,255,255,0.2);
">
  <h2 style="
    margin: 0;
    color: white;
    font-weight: 700;
    letter-spacing: 1px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  ">
    <span style="
      background: white;
      color: #4facfe;
      padding: 5px 10px;
      border-radius: 8px;
      font-size: 18px;
    ">🚀</span>
    Social App
  </h2>
</nav>
<!-- ✅ TOAST CONTAINER -->
<div id="toast-container" style="
  position: fixed;
  top: 20px;
  right: 20px;
  z-index: 9999;
"></div>

<form method="post" action="/signup">
  <div class="container d-flex justify-content-center align-items-center vh-100">
    
    <div class="card p-4 shadow" style="width: 400px;">
      
      <h3 class="text-center mb-3">Create Account</h3>

      <!-- NAME -->
      <input name="name" type="text" class="form-control mb-2" placeholder="Full Name" required>

      <!-- USERNAME -->
      <input name="username" type="text" class="form-control mb-2" placeholder="Username" required>

      <!-- EMAIL -->
      <input name="email" type="email" class="form-control mb-2" placeholder="Email" required>

      <!-- PASSWORD -->
      <input 
        name="password" 
        type="password" 
        id="password"
        class="form-control mb-2" 
        placeholder="Password"
        maxlength="14"
        required
        oninput="validatePassword()"
      >

      <!-- PASSWORD ERROR -->
      <div id="passwordError" class="text-danger mb-2" style="display:none;">
        Password must be 14 characters or less
      </div>

      <!-- SUBMIT -->
      <button class="btn btn-success w-100" type="submit">Sign Up</button>

      <!-- LOGIN LINK -->
      <p class="text-center mt-3">
        Already have an account? <a href="/">Login</a>
      </p>

    </div>
  </div>
</form>

<!-- 🔥 TOAST SCRIPT -->
<script>
function showToast(message, type = "error") {
  const toast = document.createElement("div");

  toast.innerText = message;

  toast.style.background = type === "error" ? "#ef4444" : "#22c55e";
  toast.style.color = "white";
  toast.style.padding = "12px 18px";
  toast.style.marginTop = "10px";
  toast.style.borderRadius = "8px";
  toast.style.boxShadow = "0 4px 10px rgba(0,0,0,0.1)";
  toast.style.fontWeight = "500";
  toast.style.cursor = "pointer";
  toast.style.opacity = "0";
  toast.style.transform = "translateX(50px)";
  toast.style.transition = "all 0.3s ease";

  document.getElementById("toast-container").appendChild(toast);

  // Animate in
  setTimeout(() => {
    toast.style.opacity = "1";
    toast.style.transform = "translateX(0)";
  }, 100);

  // Auto remove
  setTimeout(() => {
    toast.style.opacity = "0";
    setTimeout(() => toast.remove(), 300);
  }, 3000);

  // Manual remove
  toast.onclick = () => toast.remove();
}
</script>

<!-- 🔥 PASSWORD VALIDATION -->
<script>
function validatePassword() {
  const pass = document.getElementById("password").value;
  const error = document.getElementById("passwordError");

  if (pass.length > 14) {
    error.style.display = "block";
  } else {
    error.style.display = "none";
  }
}
</script>

<!-- 🔥 TRIGGER TOAST FROM BACKEND -->
<% if (typeof error !== 'undefined') { %>
<script>
  showToast("<%= error %>");
</script>
<% } %>
<footer style="
  position: absolute;
  bottom: 0;
  width: 100%;
  text-align: center;
  padding: 10px 0;
  backdrop-filter: blur(10px);
  background: rgba(255,255,255,0.1);
  border-top: 1px solid rgba(255,255,255,0.2);
  color: white;
  font-size: 14px;
  letter-spacing: 0.5px;
">
  © 2026 All rights reserved by Group 6
</footer>
</body>
</html>