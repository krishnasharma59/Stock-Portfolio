<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Signup</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<div class="container d-flex justify-content-center align-items-center vh-100">
  <div class="card p-4 shadow" style="width: 400px;">
    <h3 class="text-center mb-3">Create Account</h3>

    <input id="name" class="form-control mb-2" placeholder="Full Name">
    <input id="username" class="form-control mb-2" placeholder="Username">
    <input id="email" type="email" class="form-control mb-2" placeholder="Email">
    <input id="password" type="password" class="form-control mb-3" placeholder="Password">

    <button class="btn btn-success w-100" onclick="signup()">Sign Up</button>

    <p class="text-center mt-3">
      Already have an account? <a href="login.ejs">Login</a>
    </p>
  </div>
</div>

<script>
function signup() {
  const name = document.getElementById("name").value;
  const username = document.getElementById("username").value;
  const email = document.getElementById("email").value;
  const password = document.getElementById("password").value;

  if (!name || !username || !email || !password) {
    alert("Please fill all fields");
    return;
  }

  const userData = { name, username, email, password };

  console.log("User Registered:", userData);

  // TODO: Replace with backend API call
  // fetch('/api/signup', { method: 'POST', body: JSON.stringify(userData) })

  alert("Signup successful! Redirecting to login...");
  window.location.href = "login.ejs";
}
</script>

</body>
</html>